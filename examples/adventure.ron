    characters: {
        "butler": (
            name: "Edmund the Butler",
            description: "An elderly butler in a pristine uniform. His eyes hold a deep sadness, as if he's seen too much.",
            dialogue: Some((
                start: "greeting",
                nodes: {
                    "greeting": (
                        text: "Good evening. I've been expecting you. The master... well, the master is no longer with us.",
                        responses: Some([
                            (
                                text: "What happened to him?",
                                next: "master_fate",
                                conditions: None,
                                actions: None,
                            ),
                            (
                                text: "How long have you been here?",
                                next: "butler_history",
                                conditions: None,
                                actions: None,
                            ),
                            (
                                text: "I'll look around.",
                                next: "end",
                                conditions: None,
                                actions: None,
                            ),
                        ]),
                        actions: None,
                        next: None,
                    ),
                    "master_fate": (
                        text: "He vanished one night, down in the cellar. We found only his lantern, still burning. Some say he found what he was looking for. Others say it found him.",
                        responses: Some([
                            (
                                text: "What was he looking for?",
                                next: "treasure_hint",
                                conditions: None,
                                actions: None,
                            ),
                            (
                                text: "Thank you for the information.",
                                next: "end",
                                conditions: None,
                                actions: None,
                            ),
                        ]),
                        actions: None,
                        next: None,
                    ),
                    "butler_history": (
                        text: "Forty years, come next month. I've served three generations of the family. This manor holds many secrets, and I've kept them all.",
                        responses: Some([
                            (
                                text: "What kind of secrets?",
                                next: "secrets",
                                conditions: None,
                                actions: None,
                            ),
                            (
                                text: "I see.",
                                next: "end",
                                conditions: None,
                                actions: None,
                            ),
                        ]),
                        actions: None,
                        next: None,
                    ),
                    "treasure_hint": (
                        text: "The family treasure, hidden somewhere in the manor. He spent his final years obsessed with finding it. Perhaps you'll have better luck... if you're brave enough to search the dark places.",
                        responses: None,
                        actions: None,
                        next: "end",
                    ),
                    "secrets": (
                        text: "The kind that are better left undisturbed. But if you must know, check the study. The master kept his most private thoughts there.",
                        responses: None,
                        actions: None,
                        next: "end",
                    ),
                    "end": (
                        text: "If you need anything, you need only ask. I'll be here, as always.",
