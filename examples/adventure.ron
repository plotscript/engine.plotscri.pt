TextAdventure(
    title: "The Mysterious Manor",
    author: "PlotScript Team",
    description: Some("Explore a mysterious manor and uncover its secrets"),
    version: Some("1.0.0"),
    
    settings: (
        parser_mode: Natural,
        command_aliases: true,
        darkness_system: true,
        inventory_limits: false,
