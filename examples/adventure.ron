    starting_location: "entrance",
    
    locations: {
        "entrance": (
            name: "Manor Entrance",
            description: "You stand before a grand manor entrance. The heavy oak door looms before you, its brass handle gleaming in the moonlight. To the east, a garden path winds around the building.",
            exits: {
                North: "foyer",
                East: "garden",
            },
            items: ["brass_key", "note"],
            characters: [],
            dark: Some(false),
            first_visit: Some("The manor looks even more imposing than you imagined."),
            events: None,
        ),
        
        "foyer": (
            name: "Grand Foyer",
            description: "A magnificent foyer stretches before you. A crystal chandelier hangs from the vaulted ceiling, casting dancing shadows on the marble floor. Doors lead in all directions.",
            exits: {
                South: "entrance",
                North: "hallway",
                East: "library",
                West: "dining_room",
