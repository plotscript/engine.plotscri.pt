        ),
        
        "library": (
            name: "Dusty Library",
            description: "Floor-to-ceiling bookshelves line every wall. The musty smell of old paper fills the air. A reading desk sits by the window.",
            exits: {
                West: "foyer",
            },
            items: ["ancient_book", "reading_glasses"],
            characters: [],
